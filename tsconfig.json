{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "outDir": "dist",
    "rootDir": ".",

    "esModuleInterop": true,
    "skipLibCheck": true,

    "strict": false,
    "isolatedModules": true,
    "moduleDetection": "force",

    "allowJs": true,
    "resolveJsonModule": true,

    "jsx": "react-jsx",

    "paths": {
      "@/*": ["./*"]
    }
  },

  "include": [
    "server.ts",
    "src"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}
