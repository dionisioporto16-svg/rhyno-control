{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",

    "outDir": "dist",
    "rootDir": ".",

    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,

    "resolveJsonModule": true,
    "jsx": "react-jsx"
  },

  "include": [
    "server.ts"
  ]
}
